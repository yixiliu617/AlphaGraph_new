# Copy to `.env` and fill in. Anything not set falls back to the default
# in `backend/app/core/config.py`. Comment out lines you don't need.
# `.env` is gitignored — never commit credentials.

# ─── Database ───────────────────────────────────────────────────────────────
# POSTGRES_URI controls the LEGACY tables (fragments, universe, insights,
# notes). Defaults to local SQLite. Set to Postgres to fully migrate.
# POSTGRES_URI=sqlite:///./alphagraph.db
POSTGRES_URI=postgresql+psycopg2://alphagraph:alphagraph_dev@localhost:5432/alphagraph

# AUTH_DATABASE_URI controls the Phase 2 tables (app_user, oauth_session,
# user_alert, scraper_heartbeat). If unset, falls back to POSTGRES_URI —
# only override if you want auth on a different DB than the legacy tables.
# AUTH_DATABASE_URI=postgresql+psycopg2://alphagraph:alphagraph_dev@localhost:5432/alphagraph

# ─── OAuth ──────────────────────────────────────────────────────────────────
# Google: Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# - Application type: Web application
# - Authorized redirect URI: http://localhost:8000/api/v1/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft: Azure Portal → App Registrations → New registration
# - Redirect URI (Web): http://localhost:8000/api/v1/auth/microsoft/callback
# - Tenant: "common" supports personal MSA + work/school. Or use a tenant ID.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

# Where the IdP redirects back to. Match this against the Authorized URI
# you registered in Google Cloud / Azure. Must include scheme and host.
OAUTH_REDIRECT_BASE=http://localhost:8000

# Where the auth callback redirects after a successful sign-in.
FRONTEND_URL=http://localhost:3000

# Session cookie. Dev defaults are fine; set SESSION_COOKIE_SECURE=true in
# prod (requires HTTPS). SESSION_COOKIE_DOMAIN lets a single cookie cover
# api.example.com + app.example.com — leave unset for dev.
# SESSION_COOKIE_NAME=ag_session
# SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=

# JWT — used to sign the session-cookie payload. KEEP THIS SECRET in prod.
# SECRET_KEY=replace_me_with_a_long_random_string

# ─── LLM keys (optional, only set the ones you use) ─────────────────────────
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Other ──────────────────────────────────────────────────────────────────
# PINECONE_API_KEY=
# DEEPGRAM_API_KEY=
