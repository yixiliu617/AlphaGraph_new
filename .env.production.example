# Production environment variables — Render + Vercel + Neon deploy.
#
# DO NOT commit a populated copy. This file is a TEMPLATE — copy values
# into Render dashboard (Environment) and Vercel dashboard (Settings →
# Environment Variables). Do not put real secrets in git.
#
# Vars are grouped: secret (set via dashboard with sync:false), public
# (safe in render.yaml), or generated (Render generates a random value).

# ===========================================================================
# Backend (Render web + worker services)
# ===========================================================================

# ---- Database (Neon) ----
# Copy the "pooled" connection string from Neon — pooler handles many
# concurrent connections; the direct connection has a low connection cap.
POSTGRES_URI=postgresql+psycopg2://<user>:<password>@<endpoint>.neon.tech/alphagraph?sslmode=require
AUTH_DATABASE_URI=                     # leave blank — falls back to POSTGRES_URI

# ---- Storage (Backblaze B2 — S3-compatible) ----
# Pilot deploy starts on the Render Disk; switch to S3 when ready.
# When STORAGE_BACKEND=s3, set the four S3_* vars below.
STORAGE_BACKEND=fs                     # "fs" (Render Disk) or "s3"
DATA_DIR=/app/backend/data             # Render Disk mount path
S3_BUCKET=alphagraph-data              # Backblaze B2 bucket name
S3_PREFIX=                             # optional key prefix
S3_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com   # B2; for AWS leave blank
S3_REGION=us-west-002                  # B2 region; "us-east-1" for AWS

# ---- Crypto secrets ----
SECRET_KEY=<32+ random bytes>          # Render: generateValue: true
TOKEN_ENCRYPTION_KEY=<fernet key>      # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ---- OAuth — Google ----
# Authorized redirect URI must include https://<render-host>/api/v1/connections/callback/google
# AND https://<render-host>/api/v1/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=<from console.cloud.google.com>
GOOGLE_OAUTH_CLIENT_SECRET=<from console.cloud.google.com>

# ---- OAuth — Microsoft (Entra ID / Azure AD) ----
# Authorized redirect URIs must include both:
#   https://<render-host>/api/v1/connections/callback/microsoft
#   https://<render-host>/api/v1/auth/microsoft/callback
MICROSOFT_OAUTH_CLIENT_ID=<from entra.microsoft.com>
MICROSOFT_OAUTH_CLIENT_SECRET=<the "Value" from Certificates & secrets, NOT the Secret ID>
MICROSOFT_OAUTH_TENANT=common          # "common" supports both personal MSA and work/school accounts

# ---- LLM keys ----
ANTHROPIC_API_KEY=sk-ant-...           # primary; used by Engine + chat
OPENAI_API_KEY=sk-...                  # optional; for transcription / fallback
GEMINI_API_KEY=...                     # optional; used by extraction pipeline

# ---- Public URLs (set after Render assigns the .onrender.com host) ----
OAUTH_REDIRECT_BASE=https://alphagraph-backend.onrender.com
FRONTEND_URL=https://alphagraph.vercel.app
CORS_ORIGINS=https://alphagraph.vercel.app
CORS_ORIGIN_REGEX=^https://alphagraph-.*\.vercel\.app$

# ---- Cookie flags — prod = strict cross-origin ----
SESSION_COOKIE_SECURE=true             # cookies over HTTPS only
SESSION_COOKIE_SAMESITE=none           # Render and Vercel are different domains; SameSite=None required
SESSION_COOKIE_DOMAIN=                 # leave blank → host-only; set to e.g. .alphagraph.com when you have a custom domain

# ---- Misc app config ----
ENGINE_LLM=anthropic                   # 'anthropic' | 'gemini' | 'openai' for the Engine agent
ACTIVE_LLM=gemini                      # for extraction pipeline
WEB_CONCURRENCY=2                      # uvicorn workers; 2 is fine for starter Render plan

# ===========================================================================
# Frontend (Vercel — Settings → Environment Variables)
# ===========================================================================

# Server-side URL the Next app uses to talk to the backend.
# Vercel makes NEXT_PUBLIC_* vars available in the browser too.
NEXT_PUBLIC_API_URL=https://alphagraph-backend.onrender.com/api/v1
