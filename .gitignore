# Environment
.env
.env.local
.env.*.local

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/.turbo/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Generated data — rebuilt by ToplineBuilder / CalculatedLayerBuilder / ingest scripts
backend/data/filing_data/
backend/data/earnings_releases/
backend/data/earnings_fragments/
backend/data/insights/
backend/data/fragment_debug/
backend/data/Broker_report/

# Taiwan ingestion: cached ZIP/XLS (raw captures) and the derived parquet.
# Rebuildable from tools/twse_backfill.py and tools/tpex_backfill.py.
backend/data/taiwan/_raw/
backend/data/taiwan/monthly_revenue/data.parquet
backend/data/taiwan/monthly_revenue/history.parquet
backend/data/taiwan/_registry/mops_company_master.parquet

# Calendar feature bronze caches (NASDAQ JSON + Yahoo per-ticker dicts).
# Regenerable via `python -m backend.scripts.refresh_calendar_us`.
backend/data/_raw/

# Social media (X, WeChat): ingested parquet data is rebuildable via
# tools/x_backfill.py. Config + validated_accounts.json ARE committed.
backend/data/social/
!backend/data/social/.gitkeep

# Keep the config directory (ticker_groups.json etc.)
!backend/data/config/

# Audio recordings (large .wav files)
tools/audio_recorder/recordings/

# Equity prices silver layer (regenerated by `python -m backend.scripts.extractors.equity_prices --backfill`).
# 430+ ticker parquets, ~80 MB total. Never committed — too churn-y, regenerated nightly.
backend/data/financials/prices/

# Per-company IR-source bronze + silver (PDFs, transcripts, parquets).
# Regenerated from each company's IR site by the per-company extractors.
backend/data/financials/raw/
backend/data/financials/guidance/

# Other rebuildable market-data parquets.
backend/data/market_data/
backend/data/earnings_calendar/

# SQLite dev database — never committed, recreated on first run.
alphagraph.db
alphagraph.db-shm
alphagraph.db-wal
backend/alphagraph.db
backend/alphagraph.db-shm
backend/alphagraph.db-wal

# Vercel / Next.js build artifact — committed nothing.
frontend/tsconfig.tsbuildinfo

